<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/blue_navy">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Novo Lembrete"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- TÍTULO -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TÍTULO"
        android:textColor="@color/label_color"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/blue_card">

        <EditText
            android:id="@+id/edit_text_titulo_lembrete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Usar inalador"
            android:textColor="@color/white"
            android:textColorHint="@color/label_color"
            android:textSize="14sp"
            android:background="@null"
            android:padding="14dp" />

    </androidx.cardview.widget.CardView>

    <!-- HORÁRIO -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HORÁRIO"
        android:textColor="@color/label_color"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/blue_card">

        <LinearLayout
            android:id="@+id/btn_selecionar_horario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_schedule"
                app:tint="@color/turquoise_light"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_horario_selecionado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Toque para selecionar"
                android:textColor="@color/label_color"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/turquoise_light"
                android:textSize="18sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- DATA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DATA"
        android:textColor="@color/label_color"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/blue_card">

        <LinearLayout
            android:id="@+id/btn_selecionar_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/turquoise_light"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/text_data_selecionada"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Toque para selecionar"
                android:textColor="@color/label_color"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/turquoise_light"
                android:textSize="18sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>