<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B3E">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:background="#0D1B3E"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#4FC3F7"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notificações"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnMarcarTodas"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/checkbox_on_background"
            android:backgroundTint="#162040"
            app:tint="#4FC3F7"
            android:contentDescription="Marcar todas como lidas"
            android:scaleType="fitCenter"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btnExcluirTodas"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_menu_delete"
            android:backgroundTint="#162040"
            app:tint="#EF5350"
            android:contentDescription="Excluir todas"
            android:scaleType="fitCenter"
            android:padding="6dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="120dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/txtVazio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma notificação por enquanto."
                android:textColor="#8EADD4"
                android:textSize="15sp"
                android:gravity="center"
                android:paddingTop="48dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/containerNotificacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>