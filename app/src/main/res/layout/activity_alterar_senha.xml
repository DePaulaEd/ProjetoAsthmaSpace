<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_navy"
    android:fillViewport="true"
    android:fitsSystemWindows="true">
    >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="48dp"
            android:paddingBottom="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@color/blue_navy">

            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/blue_cyan"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                android:padding="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Alterar Senha"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <!-- CONTEÚDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- Subtítulo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Por segurança, confirme sua senha atual antes de definir uma nova."
                android:textColor="@color/label_color"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="24dp" />

            <!-- CARD SENHA ATUAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SENHA ATUAL"
                android:textColor="@color/label_color"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/turquoise_light"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etSenhaAtual"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Digite sua senha atual"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/label_color"
                        android:textSize="14sp"
                        android:background="@null"
                        android:padding="0dp" />

                    <ImageButton
                        android:id="@+id/btnToggleSenhaAtual"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/label_color"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Mostrar senha" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- DIVISOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/blue_divider"
                android:layout_marginBottom="20dp" />

            <!-- NOVA SENHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOVA SENHA"
                android:textColor="@color/label_color"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/turquoise_light"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etNovaSenha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Digite a nova senha"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/label_color"
                        android:textSize="14sp"
                        android:background="@null"
                        android:padding="0dp" />

                    <ImageButton
                        android:id="@+id/btnToggleNovaSenha"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/label_color"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Mostrar senha" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CONFIRMAR NOVA SENHA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONFIRMAR NOVA SENHA"
                android:textColor="@color/label_color"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/turquoise_light"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etConfirmarSenha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Confirme a nova senha"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/label_color"
                        android:textSize="14sp"
                        android:background="@null"
                        android:padding="0dp" />

                    <ImageButton
                        android:id="@+id/btnToggleConfirmarSenha"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/label_color"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Mostrar senha" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- DICA -->
            <!-- DICA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/turquoise_light"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mínimo de 6 caracteres. Use letras e números para maior segurança."
                        android:textColor="@color/label_color"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- BOTÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnCancelar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancelar"
                    android:textColor="@color/label_color"
                    android:textSize="14sp"
                    android:backgroundTint="@color/blue_card" />

                <Button
                    android:id="@+id/btnSalvarSenha"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="Salvar senha"
                    android:textColor="@color/blue_navy"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/turquoise_light" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>