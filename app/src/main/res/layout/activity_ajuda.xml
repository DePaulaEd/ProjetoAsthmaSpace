<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B3E">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:background="#0D1B3E"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#4FC3F7"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ajuda"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05" />

        <!-- espaço para centralizar o título -->
        <View android:layout_width="40dp" android:layout_height="40dp" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="120dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="8dp">

            <!-- Introdução -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🫁" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O que é o Asthma Space?" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="O Asthma Space é um aplicativo criado para ajudar pacientes com asma a monitorar sua saúde, registrar sintomas e manter suas informações médicas organizadas em um só lugar."
                        android:textColor="#8EADD4"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Seção: Perfil -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FUNCIONALIDADES"
                android:textColor="#4FC3F7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Informações Pessoais" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Acesse e edite seus dados pessoais como nome, telefone, endereço, medicamentos em uso e contato de emergência. Mantenha sempre atualizado para facilitar o atendimento médico." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🩺" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Histórico de Sintomas" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Registre episódios de crise com data, horário e intensidade. Marque os sintomas presentes como tosse, falta de ar ou chiado. Esse histórico pode ser compartilhado com seu médico." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔔" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notificações" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Receba alertas importantes como avisos de qualidade do ar, orientações médicas e comunicados do sistema. Fique sempre informado sobre condições que podem afetar sua respiração." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Configurações" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Personalize o aplicativo de acordo com suas preferências. Gerencie sua conta, altere senha e controle as permissões do app." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Seção: Emergência -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMERGÊNCIA"
                android:textColor="#FF6B6B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#2A1020">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚨" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Em caso de crise grave" android:textColor="#FF6B6B" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Se sentir falta de ar intensa, lábios azulados ou dificuldade para falar, ligue imediatamente para o SAMU (192) ou vá ao pronto-socorro mais próximo. Não espere os sintomas piorarem." android:textColor="#E8A0A0" android:textSize="14sp" android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Seção: Dúvidas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DÚVIDAS FREQUENTES"
                android:textColor="#4FC3F7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Como altero minha senha?" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Acesse Configurações > Conta > Alterar senha e siga as instruções." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Meus dados são seguros?" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sim. Todas as informações são transmitidas de forma criptografada e armazenadas com segurança. Apenas você tem acesso aos seus dados." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162040">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Preciso de internet para usar o app?" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sim. O Asthma Space precisa de conexão com a internet para sincronizar seus dados com o servidor e exibir notificações atualizadas." android:textColor="#8EADD4" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>